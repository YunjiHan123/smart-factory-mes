spring.application.name=mes-backend

spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.datasource.hikari.maximum-pool-size=${DB_POOL_MAX_SIZE:10}
spring.datasource.hikari.minimum-idle=${DB_POOL_MIN_IDLE:2}

spring.sql.init.mode=${SQL_INIT_MODE:always}
spring.sql.init.schema-locations=classpath:schema.sql
spring.sql.init.continue-on-error=false

mybatis.configuration.map-underscore-to-camel-case=true

mes.simulation.enabled=${MES_SIMULATION_ENABLED:true}
mes.simulation.fixed-delay-ms=${MES_SIMULATION_DELAY_MS:5000}
mes.simulation.initial-delay-ms=${MES_SIMULATION_INITIAL_DELAY_MS:5000}
mes.simulation.bootstrap-ticks=${MES_SIMULATION_BOOTSTRAP_TICKS:12}
mes.simulation.dashboard-trend-hours=${MES_SIMULATION_DASHBOARD_TREND_HOURS:8}
